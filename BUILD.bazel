    sdk_generation_tree(
        name = spec["target"],
        language = spec["language"],
        # Snippet lint is downstream of the checked generated artifact. The
        # dedicated openapi_check target owns backend -> openapi freshness.
        openapi = "//open-source/docs/api-reference:checked_openapi_json",
        srcs = [
            ":sdk_generation_common_inputs",
            ":%s_sdk_seed_inputs" % spec["language"],
        ],
        format = False,
        tags = MANUAL_LOCAL_TAGS + ["generated-artifact", "snippet-sdk"],
    )
    for spec in SDK_LANGUAGE_SPECS
]

