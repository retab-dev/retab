load("//tools/bazel:defs.bzl", "MANUAL_LOCAL_TAGS")
load("//tools/bazel:sdk_generation.bzl", "sdk_generation_tree")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "generation_inputs",
    srcs = glob([
        "clients/**",
    ]) + [
        "//.scripts:sdk_generation_scripts",
        "//open-source/docs/api-reference:checked_openapi_json",
        "//open-source/sdk/cli:sources",
    ],
)

sh_test(
    name = "check_python",
    srcs = ["//tools/bazel:check_generated_sdk_tree.sh"],
    args = [
        "python",
        "$(location :generated_python_sdk)",
        "open-source/sdk/clients/python",
    ],
    data = [
        ":generated_python_sdk",
        ":generation_inputs",
    ],
    tags = MANUAL_LOCAL_TAGS + ["generated-check"],
)

sh_test(
    name = "check_node",
    srcs = ["//tools/bazel:check_generated_sdk_tree.sh"],
    args = [
        "node",
        "$(location :generated_node_sdk)",
        "open-source/sdk/clients/node",
    ],
    data = [
        ":generated_node_sdk",
        ":generation_inputs",
    ],
    tags = MANUAL_LOCAL_TAGS + ["generated-check"],
)

sdk_generation_tree(
    name = "generated_python_sdk",
    language = "python",
    openapi = "//open-source/docs/api-reference:openapi_json",
    srcs = [":generation_inputs"],
    tags = MANUAL_LOCAL_TAGS + ["generated-artifact"],
)

