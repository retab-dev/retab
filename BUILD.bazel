# Fully hermetic Python SDK drift check (blueprint Phase 4, Python; mirrors
# check_node): runs SANDBOXED with no network and is cached on no-op reruns. Both
# inputs are Bazel-declared TreeArtifacts:
#   * generated_python_sdk_formatted -- the raw generator output (sandboxed, from
#     the committed OpenAPI contract on the pinned Node toolchain via the
#     lockfile-materialized oagen_npm closure) re-formatted with the
#     lockfile-pinned, vendored ruff 0.15.13 binary via
#     //tools/bazel/ruff_sdk_tree (line-length 180, target-version py312,
#     --isolated -- the committed pyproject.toml [tool.ruff] config).
#   * committed_python_sdk_tree -- the committed retab/resources/** +
#     retab/types/** generated .py files + manifest staged into a tree.
# diff_generated_sdk_tree.sh compares the two inside the sandbox (normalizing the
# manifest generatedAt timestamp), so nothing reaches the live working tree. This
# replaces the old LOCAL/no-sandbox check that regenerated on the host and read
# the committed tree via RETAB_REPO_ROOT.
sh_test(
    name = "check_python",
    srcs = ["//tools/bazel:diff_generated_sdk_tree.sh"],
    args = [
        "python",
        "$(location //open-source/sdk/clients/python:generated_python_sdk_formatted)",
        "$(location //open-source/sdk/clients/python:committed_python_sdk_tree)",
    ],
    data = [
        "//open-source/sdk/clients/python:committed_python_sdk_tree",
        "//open-source/sdk/clients/python:generated_python_sdk_formatted",
    ],
    tags = ["generated-check"],
)

# Fully hermetic Node SDK drift check (blueprint Phase 4, gold standard): runs
# SANDBOXED with no network and is cached on no-op reruns. Both inputs are
# Bazel-declared TreeArtifacts:
#   * generated_node_sdk_formatted -- the raw generator output (sandboxed, from
#     the committed OpenAPI contract on the pinned Node toolchain via the
#     lockfile-materialized oagen_npm closure) re-formatted with the Node SDK
#     client's own vendored prettier (node_sdk_npm).
#   * committed_node_sdk_tree -- the committed src/ + manifest staged into a tree.
# diff_generated_sdk_tree.sh compares the two inside the sandbox (normalizing the
# manifest generatedAt timestamp), so nothing reaches the live working tree. This
# replaces the old LOCAL/no-sandbox check that regenerated on the host and read
# the committed tree via RETAB_REPO_ROOT. The retab-node-oagen-emitter service
# boundary selects this target for real regenerate-and-diff drift coverage,
# instead of the //api-quality:unit_tests proxy other (still-manual) languages
# use.
sh_test(
    name = "check_node",
    srcs = ["//tools/bazel:diff_generated_sdk_tree.sh"],
    args = [
        "node",
        "$(location //open-source/sdk/clients/node:generated_node_sdk_formatted)",
        "$(location //open-source/sdk/clients/node:committed_node_sdk_tree)",
    ],
    data = [
        "//open-source/sdk/clients/node:committed_node_sdk_tree",
        "//open-source/sdk/clients/node:generated_node_sdk_formatted",
    ],
    tags = ["generated-check"],
)

sdk_generation_tree(
    name = "generated_python_sdk",
    language = "python",
    openapi = "//open-source/docs/api-reference:openapi_json",
    srcs = [":generation_inputs"],
    tags = MANUAL_LOCAL_TAGS + ["generated-artifact"],
)

# Generate from the committed OpenAPI contract (checked_openapi_json), not the
# live-backend genrule, so SDK drift is decoupled from backend regeneration and
# the check is hermetic. Pinned Node toolchain is threaded in by the rule.
sdk_generation_tree(
    name = "generated_node_sdk",
    language = "node",
    openapi = "//open-source/docs/api-reference:checked_openapi_json",
    srcs = [":generation_inputs"],
    tags = LOCAL_TAGS + ["generated-artifact"],
)

# Fully hermetic Go SDK drift check (blueprint Phase 4, Go): mirrors check_node.
# Runs SANDBOXED with no network and is cached on no-op reruns. Both inputs are
# Bazel-declared TreeArtifacts:
#   * generated_go_sdk_formatted -- the raw generator output (sandboxed, from the
#     committed OpenAPI contract on the pinned Node toolchain via the lockfile-
#     materialized oagen_npm closure) re-formatted with //tools/bazel/gofmt_sdk_tree
#     (a rules_go go_binary running the gofmt engine on the pinned Go toolchain).
#   * committed_go_sdk_tree -- the committed non-test root *.go + go.mod + manifest
#     staged into a tree.
# diff_generated_sdk_tree.sh compares the two inside the sandbox (normalizing the
# manifest generatedAt timestamp), so nothing reaches the live working tree. This
# replaces the old LOCAL/no-sandbox check that regenerated on the host and read
# the committed tree via RETAB_REPO_ROOT.
sh_test(
    name = "check_go",
    srcs = ["//tools/bazel:diff_generated_sdk_tree.sh"],
    args = [
        "go",
        "$(location //open-source/sdk/clients/go:generated_go_sdk_formatted)",
        "$(location //open-source/sdk/clients/go:committed_go_sdk_tree)",
    ],
    data = [
        "//open-source/sdk/clients/go:committed_go_sdk_tree",
        "//open-source/sdk/clients/go:generated_go_sdk_formatted",
    ],
    tags = ["generated-check"],
)

# Fully hermetic Rust SDK drift check (blueprint Phase 4, Rust): mirrors
# check_go/check_node. Runs SANDBOXED with no network and is cached on no-op
# reruns. Both inputs are Bazel-declared TreeArtifacts:
#   * generated_rust_sdk_formatted -- the raw generator output (sandboxed, from
#     the committed OpenAPI contract on the pinned Node toolchain via the
#     lockfile-materialized oagen_npm closure) re-formatted with the pinned,
#     vendored rustfmt binary via //tools/bazel/rustfmt_sdk_tree (the rustc
#     runtime libs travel with it; the format script points the dynamic loader
#     at their dir). Scoped to src/** + manifest (Node parity).
#   * committed_rust_sdk_tree -- the committed src/**/*.rs + manifest staged into
#     a tree. The hand-bumped Cargo.toml/Cargo.lock, LICENSE, README and the
#     hand-written tests/ are NOT generated and are excluded.
# diff_generated_sdk_tree.sh compares the two inside the sandbox (normalizing the
# manifest generatedAt timestamp), so nothing reaches the live working tree. This
# replaces the old LOCAL/no-sandbox check that regenerated on the host and read
# the committed tree via RETAB_REPO_ROOT.
sh_test(
    name = "check_rust",
    srcs = ["//tools/bazel:diff_generated_sdk_tree.sh"],
    args = [
        "rust",
        "$(location //open-source/sdk/clients/rust:generated_rust_sdk_formatted)",
        "$(location //open-source/sdk/clients/rust:committed_rust_sdk_tree)",
    ],
    data = [
        "//open-source/sdk/clients/rust:committed_rust_sdk_tree",
        "//open-source/sdk/clients/rust:generated_rust_sdk_formatted",
    ],
    tags = ["generated-check"],
)

# Fully hermetic .NET SDK drift check (blueprint Phase 4, gold standard): runs
# SANDBOXED with no network and is cached on no-op reruns. Both inputs are
# Bazel-declared TreeArtifacts:
#   * generated_dotnet_sdk_formatted -- the raw generator output (sandboxed, from
#     the committed OpenAPI contract on the pinned Node toolchain via the
#     lockfile-materialized oagen_npm closure), scoped to src/ + manifest. The
#     dotnet emitter already emits correctly-formatted C#, so unlike Node/Go/Java
#     there is NO downstream formatter step and NO .NET SDK toolchain.
#   * committed_dotnet_sdk_tree -- the committed src/ + manifest staged into a tree.
# diff_generated_sdk_tree.sh compares the two inside the sandbox (normalizing the
# manifest generatedAt timestamp). The release Version in Retab.csproj and the
# hand-extended tests/ are intentionally out of scope (Node parity excludes
# package.json + tests). The retab-dotnet-oagen-emitter service boundary selects
# this target for real regenerate-and-diff drift coverage instead of the
# //api-quality:unit_tests proxy.
sh_test(
    name = "check_dotnet",
    srcs = ["//tools/bazel:diff_generated_sdk_tree.sh"],
    args = [
        "dotnet",
        "$(location //open-source/sdk/clients/dotnet:generated_dotnet_sdk_formatted)",
        "$(location //open-source/sdk/clients/dotnet:committed_dotnet_sdk_tree)",
    ],
    data = [
        "//open-source/sdk/clients/dotnet:committed_dotnet_sdk_tree",
        "//open-source/sdk/clients/dotnet:generated_dotnet_sdk_formatted",
    ],
    tags = ["generated-check"],
)

