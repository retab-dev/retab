{
  "name": "retab/retab",
  "description": "Retab API client for PHP",
  "type": "library",
  "license": "MIT",
  "keywords": ["retab", "api", "sdk", "ocr", "document-extraction", "ai", "llm"],
  "homepage": "https://retab.com",
  "support": {
    "issues": "https://github.com/retab-dev/retab-php/issues",
    "source": "https://github.com/retab-dev/retab-php",
    "docs": "https://docs.retab.com"
  },
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  },
  "scripts": {
    "lint": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --using-cache=no",
    "lint:fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --using-cache=no",
    "stan": "vendor/bin/phpstan analyse",
    "test": "vendor/bin/phpunit"
  },
  "autoload": {
    "psr-4": {
      "Retab\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Retab\\Tests\\": "tests/"
    }
  },
  "_comment": "@oagen-ignore-file — hand-maintained after initial scaffold."
}
