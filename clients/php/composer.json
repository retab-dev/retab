{
  "name": "retab/retab",
  "description": "Retab API client for PHP",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Retab\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Retab\\Tests\\": "tests/"
    }
  },
  "_comment": "@oagen-ignore-file — hand-maintained after initial scaffold."
}
