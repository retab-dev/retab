# ──────────────────────────────────────────────────────────────────────────────
# .env.local.example — template for the Python SDK local e2e test environment.
#
# Copy this file to `.env.local` in the same directory and fill in a real local
# API key, then run the SDK suite against your local stack:
#
#   qa/e2e/local-harness/run_e2e.sh sdk-local
#
# (run_e2e.sh will auto-seed .env.local from this example if it is missing.)
#
# The SDK test conftest loads this file when invoked with `--local` and asserts
# both variables below are present, so neither may be empty.
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the local main_server API gateway. The local dev stack serves the
# API on port 4000; the SDK strips any trailing /v<N> suffix automatically.
RETAB_API_BASE_URL=http://localhost:4000

# A Retab API key valid against your LOCAL stack. Create one in the local
# dashboard (http://localhost:3000) or via the API, then paste it here.
RETAB_API_KEY=<local-key>
